                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <ui:TextBox
                                                                                                        Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                                                                                        PlaceholderText="{Binding [State.TransitionMethod.ExpressionPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,8,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.SwitchMode], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <ComboBox
                                                                                                        ItemsSource="{Binding SwitchModes, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                                        SelectedValue="{Binding SwitchMode}"
                                                                                                        SelectedValuePath="Value"
                                                                                                        DisplayMemberPath="Display" />
                                                                                                </StackPanel>

                                                                                                <StackPanel
                                                                                                    Visibility="{Binding IsOnce, Converter={StaticResource BoolToVisibility}}"
                                                                                                    Margin="0,4,0,0">
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,0,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.Probability], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <ui:NumberBox
                                                                                                        Value="{Binding Weight}"
                                                                                                        Minimum="0"
                                                                                                        ClearButtonEnabled="True" />
                                                                                                </StackPanel>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>

                                                                        <components:PhaseEditControl
                                                                            PhaseSource="{Binding}"
                                                                            AddPhaseCommand="{Binding DataContext.AddPhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            DeletePhaseCommand="{Binding DataContext.DeletePhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </ui:CardExpander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 记忆配置 (一行一个) -->
                        <StackPanel x:Name="MemoryPanel" Visibility="Collapsed">
                            <TextBlock Text="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,16" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.RecallTopK], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Memory.RecallTopK}"
                                          Minimum="1"
                                          Maximum="100"
                                          Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.TokenBudget], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Memory.TokenBudget}"
                                          Minimum="100"
                                          Maximum="10000"
                                          Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.MinRelevance], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Memory.MinRelevance}"
                                          Minimum="0"
                                          Maximum="1"
                                          Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.TimeDecayLambda], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Memory.TimeDecayLambda}"
                                          Minimum="0"
                                          Maximum="1" />
                        </StackPanel>

                        <!-- 知识检索配置 (一行一个) -->
                        <StackPanel x:Name="RetrievalPanel" Visibility="Collapsed">
                            <TextBlock
                                Text="{Binding [Knowledge.Retrieval.ConfigTitle], Source={x:Static loc:Loc.Instance}}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,16" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.SemanticTopK], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Knowledge.SemanticTopK}"
                                          Minimum="1"
                                          Maximum="100"
                                          Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.TokenBudget], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Knowledge.TokenBudget}"
                                          Minimum="100"
                                          Maximum="10000"
                                          Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.MinRelevance], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <ui:NumberBox Value="{Binding Knowledge.MinRelevance}"
                                          Minimum="0"
                                          Maximum="1" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <ui:Button Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                               Margin="0,0,8,0"
                               Click="OnCancelClick" />
                    <ui:Button Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                               Appearance="Primary"
                               Click="OnSaveClick"
                               IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
