<ui:FluentWindow x:Class="DirectorPrompt.Views.UpdateWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 Title="{Binding [Update.Title], Source={x:Static loc:Loc.Instance}}"
                 Width="420"
                 MinWidth="0"
                 MinHeight="0"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">
    <StackPanel>
        <ui:TitleBar x:Name="WindowTitleBar"
                     Margin="24,8,24,0"
                     ShowMaximize="False"
                     ShowClose="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel x:Name="ProgressPanel"
                    Margin="24,16,24,20">
            <TextBlock x:Name="StatusText"
                       FontSize="14"
                       Margin="0,0,0,12" />

            <Grid Margin="0, 12, 0, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ProgressBar x:Name="ProgressBar"
                             Grid.Column="0"
                             IsIndeterminate="True"
                             Height="8"
                             Minimum="0"
                             Maximum="100" />

                <TextBlock x:Name="ProgressText"
                           Grid.Column="1"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="Collapsed" />
            </Grid>
        </StackPanel>

        <StackPanel x:Name="ErrorPanel"
                    Margin="24,16,24,20"
                    Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <ui:Button x:Name="CloseButton"
                       HorizontalAlignment="Right"
                       Padding="20,6"
                       Click="OnCloseClick" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
