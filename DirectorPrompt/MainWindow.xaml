<ui:FluentWindow x:Class="DirectorPrompt.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
                 Title="DirectorPrompt"
                 Width="1280"
                 Height="800"
                 MinWidth="960"
                 MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="DirectorPrompt">
            <ui:TitleBar.Icon>
                <ui:ImageIcon />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="项目"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="1"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding Projects}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding CurrentProject}" />
                <TextBlock Grid.Column="2"
                           Text="对话"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="3"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding Sessions}"
                          DisplayMemberPath="Title"
                          SelectedItem="{Binding CurrentSession}"
                          IsEnabled="{Binding IsProjectSelected}" />
                <ui:Button Grid.Column="4"
                           Content="新对话"
                           Icon="Add24"
                           Appearance="Secondary"
                           Margin="0,0,4,0"
                           Padding="12,6"
                           Command="{Binding NewSessionCommand}"
                           IsEnabled="{Binding IsProjectSelected}" />
                <ui:Button Grid.Column="5"
                           Content="新建项目"
                           Icon="Add24"
                           Appearance="Secondary"
                           Margin="0,0,4,0"
                           Padding="12,6"
                           Command="{Binding NewProjectCommand}" />
                <ui:Button Grid.Column="6"
                           Content="编辑项目"
                           Icon="Edit24"
                           Appearance="Secondary"
                           Margin="0,0,4,0"
                           Padding="12,6"
                           Command="{Binding EditProjectCommand}"
                           IsEnabled="{Binding IsProjectSelected}"
                           HorizontalAlignment="Left" />
                <ui:Button Grid.Column="7"
                           Content="设置"
                           Icon="Settings24"
                           Appearance="Secondary"
                           Padding="12,6"
                           Command="{Binding OpenSettingsCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding PipelineStages}"
                              Margin="16,4,16,4"
                              Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource ControlElevationBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="进行中">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="完成">
                                                <Setter Property="Opacity" Value="0.6" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Stage}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,8">
                    <ItemsControl ItemsSource="{Binding Dialog.Entries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        MaxWidth="720"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource ControlElevationBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding IsDirector, Converter={x:Static vm:DialogEntryRoleConverter.Instance}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Top" />

                                            <ui:Button Grid.Column="2"
                                                       Icon="MoreHorizontal24"
                                                       Appearance="Secondary"
                                                       Padding="6,4"
                                                       VerticalAlignment="Top"
                                                       Visibility="{Binding IsLast, Converter={StaticResource BoolToVisibility}}">
                                                <ui:Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="重写"
                                                                  Click="OnRewriteRound"
                                                                  Tag="{Binding}" />
                                                        <MenuItem Header="删除此轮"
                                                                  Click="OnDeleteRound"
                                                                  Tag="{Binding}" />
                                                    </ContextMenu>
                                                </ui:Button.ContextMenu>
                                            </ui:Button>
                                        </Grid>

                                        <Expander Header="思考过程"
                                                  Margin="0,4,0,0"
                                                  FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasThinking, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding Thinking}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0" />
                                        </Expander>

                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}}" />

                                        <ContentControl Margin="0,4,0,0">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNarrative}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                            <FlowDocumentScrollViewer Document="{Binding Document}"
                                                                      IsSelectionEnabled="True"
                                                                      VerticalScrollBarVisibility="Hidden" />
                                        </ContentControl>

                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding IsDirector, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DirectiveInput.Directives}"
                                      Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="10,6"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TypeDisplay}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <ui:Button Appearance="Secondary"
                                                           Icon="ArrowUp24"
                                                           Padding="8,6"
                                                           Margin="2,0"
                                                           Command="{Binding DataContext.DirectiveInput.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Appearance="Secondary"
                                                           Icon="ArrowDown24"
                                                           Padding="8,6"
                                                           Margin="2,0"
                                                           Command="{Binding DataContext.DirectiveInput.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Appearance="Secondary"
                                                           Icon="Delete24"
                                                           Padding="8,6"
                                                           Margin="2,0"
                                                           Command="{Binding DataContext.DirectiveInput.RemoveDirectiveCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Margin="0,0,4,0"
                                      SelectedIndex="0"
                                      SelectionChanged="OnDirectiveTypeChanged">
                                <ComboBoxItem Content="剧情" />
                                <ComboBoxItem Content="基调" />
                                <ComboBoxItem Content="临时约束" />
                                <ComboBoxItem Content="时间/场景变更" />
                            </ComboBox>
                            <ui:TextBox Grid.Column="1"
                                        Margin="4,0"
                                        PlaceholderText="输入指令内容…"
                                        Text="{Binding DirectiveInput.InputContent, UpdateSourceTrigger=PropertyChanged}"
                                        KeyDown="OnInputKeyDown" />
                            <ui:Button Grid.Column="2"
                                       Content="添加"
                                       Icon="Add24"
                                       Margin="4,0"
                                       Padding="12,6"
                                       Command="{Binding DirectiveInput.AddDirectiveCommand}" />
                            <ui:Button Grid.Column="3"
                                       Content="发送"
                                       Icon="Send24"
                                       Appearance="Primary"
                                       Margin="4,0,0,0"
                                       Padding="16,6"
                                       Command="{Binding SendDirectivesCommand}"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="3"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8,8,8,8">
                <StackPanel>
                    <ui:CardExpander Header="状态栏"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="场景" Foreground="Gray" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="时间线" Foreground="Gray" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding StatePanel.TimelineLabel}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="生效指令"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding TtlLabel}"
                                                       FontSize="11"
                                                       Foreground="Gray"
                                                       Visibility="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>

                    <ui:CardExpander Header="人物列表"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding CharacterPanel.Characters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="Gray" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="Gray"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</ui:FluentWindow>
