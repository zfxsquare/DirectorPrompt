<ui:FluentWindow x:Class="DirectorPrompt.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
                 Title="{Binding [Settings.Title], Source={x:Static loc:Loc.Instance}}"
                 Width="960"
                 Height="800"
                 MinWidth="600"
                 MinHeight="480"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Icon="pack://application:,,,/Assets/Images/Icon.ico">
    <ui:FluentWindow.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding [Settings.Title], Source={x:Static loc:Loc.Instance}}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0"
                      x:Name="NavList"
                      Background="{DynamicResource ControlFillColorTransparentBrush}"
                      BorderThickness="0"
                      Padding="4"
                      SelectionChanged="OnNavSelectionChanged"
                      SelectedIndex="0">
                <ListViewItem Tag="agents" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Bot24" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding [Settings.Agent.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="embedding" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DataLine24" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="language" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="LocalLanguage24" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding [Settings.Language.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
            </ListView>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <StackPanel x:Name="AgentsPanel" Visibility="Visible">
                            <TextBlock Text="{Binding [Settings.Agent.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock
                                Text="{Binding [Settings.Agent.Description], Source={x:Static loc:Loc.Instance}}"
                                FontSize="12"
                                Foreground="Gray"
                                Margin="0,0,0,16" />

                            <ItemsControl ItemsSource="{Binding Agents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardExpander Margin="0,0,0,8" IsExpanded="True">
                                            <ui:CardExpander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding RoleDisplay}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding ModelName}"
                                                               Foreground="#569CD6"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </ui:CardExpander.Header>

                                            <StackPanel>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.Provider], 
                                                               Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{x:Static vm:AgentSettingViewModel.AvailableProviders}"
                                                              SelectedItem="{Binding Provider}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.Endpoint], 
                                                               Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="{Binding [Settings.Agent.Placeholder.Endpoint], Source={x:Static loc:Loc.Instance}}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.APIKey], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Text="{Binding APIKey, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="{Binding [Settings.Agent.Placeholder.APIKey], Source={x:Static loc:Loc.Instance}}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.ModelName], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1"
                                                              IsEditable="True"
                                                              ItemsSource="{Binding AvailableModels}"
                                                              Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" />
                                                    <ui:Button Grid.Column="2"
                                                               Content="{Binding [Settings.Agent.FetchModels], Source={x:Static loc:Loc.Instance}}"
                                                               Icon="ArrowDownload24"
                                                               Appearance="Secondary"
                                                               Margin="8,0,0,0"
                                                               Command="{Binding DataContext.FetchAgentModelsCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                               CommandParameter="{Binding}"
                                                               IsEnabled="{Binding IsFetchingModels, Converter={StaticResource InverseBool}}" />
                                                </Grid>

                                                <TextBlock Text="{Binding ModelFetchMessage}"
                                                           Margin="100,0,0,8"
                                                           TextWrapping="Wrap"
                                                           Foreground="Gray"
                                                           FontSize="12" />

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.Temperature], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <ui:NumberBox Grid.Column="1"
                                                                  Value="{Binding Temperature}"
                                                                  Minimum="0"
                                                                  Maximum="2"
                                                                  SpinButtonPlacementMode="Compact" />
                                                </Grid>

                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:Button
                                                        Grid.Column="0"
                                                        Content="{Binding [Settings.Agent.TestConnection], Source={x:Static loc:Loc.Instance}}"
                                                        Icon="PlugConnected24"
                                                        Appearance="Secondary"
                                                        Margin="0,0,0,0"
                                                        Command="{Binding DataContext.TestAgentConnectionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBool}}" />

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{Binding ConnectionMessage}"
                                                        Margin="0,0,0,0"
                                                        TextWrapping="Wrap"
                                                        VerticalAlignment="Center"
                                                        FontSize="12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="Gray" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ConnectionSuccess}"
                                                                            Value="True">
                                                                        <Setter Property="Foreground" Value="#107C10" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ConnectionSuccess}"
                                                                            Value="False">
                                                                        <Setter Property="Foreground" Value="OrangeRed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                </Grid>

                                            </StackPanel>
                                        </ui:CardExpander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="EmbeddingPanel" Visibility="Collapsed">
                            <TextBlock Text="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock
                                Text="{Binding [Settings.Embedding.Description], Source={x:Static loc:Loc.Instance}}"
                                FontSize="12"
                                Foreground="Gray"
                                Margin="0,0,0,16" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Agent.Provider], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{x:Static vm:AgentSettingViewModel.AvailableProviders}"
                                          SelectedItem="{Binding Embedding.Provider}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Agent.Endpoint], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <ui:TextBox Grid.Column="1"
                                            Text="{Binding Embedding.Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Binding [Settings.Agent.Placeholder.Endpoint], Source={x:Static loc:Loc.Instance}}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Agent.APIKey], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <ui:TextBox Grid.Column="1"
                                            Text="{Binding Embedding.APIKey, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Binding [Settings.Agent.Placeholder.APIKey], Source={x:Static loc:Loc.Instance}}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Agent.ModelName], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          IsEditable="True"
                                          ItemsSource="{Binding Embedding.AvailableModels}"
                                          Text="{Binding Embedding.ModelName, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:Button Grid.Column="2"
                                           Content="{Binding [Settings.Agent.FetchModels], Source={x:Static loc:Loc.Instance}}"
                                           Icon="ArrowDownload24"
                                           Appearance="Secondary"
                                           Margin="8,0,0,0"
                                           Command="{Binding FetchEmbeddingModelsCommand}"
                                           IsEnabled="{Binding Embedding.IsFetchingModels, Converter={StaticResource InverseBool}}" />
                            </Grid>

                            <TextBlock Text="{Binding Embedding.ModelFetchMessage}"
                                       Margin="100,0,0,8"
                                       TextWrapping="Wrap"
                                       Foreground="Gray"
                                       FontSize="12" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0"
                                           Content="{Binding [Settings.Agent.TestConnection], Source={x:Static loc:Loc.Instance}}"
                                           Icon="PlugConnected24"
                                           Appearance="Secondary"
                                           Command="{Binding TestEmbeddingConnectionCommand}"
                                           IsEnabled="{Binding Embedding.IsTestingConnection, Converter={StaticResource InverseBool}}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Embedding.ConnectionMessage}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Embedding.ConnectionSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="#107C10" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Embedding.ConnectionSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="OrangeRed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="LanguagePanel" Visibility="Collapsed">
                            <TextBlock Text="{Binding [Settings.Language.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock
                                Text="{Binding [Settings.Language.Description], Source={x:Static loc:Loc.Instance}}"
                                FontSize="12"
                                Foreground="Gray"
                                Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Language.Language], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          DisplayMemberPath="Value"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedLanguage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <ui:Button Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                               Margin="0,0,8,0"
                               Click="OnCancelClick" />
                    <ui:Button Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                               Appearance="Primary"
                               Click="OnSaveClick"
                               IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
