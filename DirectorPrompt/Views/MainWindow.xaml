<ui:FluentWindow x:Class="DirectorPrompt.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
                 Title="DirectorPrompt"
                 Width="1280"
                 Height="800"
                 MinWidth="960"
                 MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Icon="pack://application:,,,/Assets/Images/Icon.ico">
    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <ContextMenu x:Key="ProjectItemContextMenu" x:Shared="False">
            <MenuItem
                Header="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}"
                Click="OnEditProjectItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem
                Header="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                Click="OnDeleteProjectItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <ContextMenu x:Key="SessionItemContextMenu" x:Shared="False">
            <MenuItem
                Header="{Binding [Common.Rename], Source={x:Static loc:Loc.Instance}}"
                Click="OnRenameSessionItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem
                Header="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                Click="OnDeleteSessionItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="DirectorPrompt">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Navigation.Project], Source={x:Static loc:Loc.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <ComboBox Width="180"
                              Margin="0,0,4,0"
                              ItemsSource="{Binding Projects}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding CurrentProject}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Setter Property="ContextMenu" Value="{StaticResource ProjectItemContextMenu}" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Command="{Binding NewProjectCommand}"
                               ToolTip="{Binding [Navigation.NewProject], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="Add24" />
                    </ui:Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="1"
                        Background="{DynamicResource ControlElevationBorderBrush}"
                        Margin="12,2"
                        VerticalAlignment="Stretch" />

                <TextBlock Grid.Column="2"
                           Text="{Binding [Navigation.Session], Source={x:Static loc:Loc.Instance}}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox Width="180"
                              Margin="0,0,4,0"
                              ItemsSource="{Binding Sessions}"
                              DisplayMemberPath="Title"
                              SelectedItem="{Binding CurrentSession}"
                              IsEnabled="{Binding IsProjectSelected}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Setter Property="ContextMenu" Value="{StaticResource SessionItemContextMenu}" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Command="{Binding NewSessionCommand}"
                               IsEnabled="{Binding IsProjectSelected}"
                               ToolTip="{Binding [Navigation.NewSession], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="Add24" />
                    </ui:Button>
                </StackPanel>

                <ui:Button Grid.Column="5"
                           Content="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}"
                           Icon="Settings24"
                           Appearance="Secondary"
                           Padding="12,6"
                           Command="{Binding OpenSettingsCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding PipelineStages}"
                              Margin="16,4,16,4"
                              Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource ControlElevationBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                <Setter Property="Opacity" Value="0.6" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Stage}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,8">
                    <ItemsControl ItemsSource="{Binding Dialog.Entries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        MaxWidth="720"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource ControlElevationBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirector}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Role}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Top" />

                                            <Button Grid.Column="2"
                                                    Click="OnMoreButtonClick"
                                                    Padding="6,2"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding IsLast, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="⋯" FontSize="14" />
                                                <Button.ContextMenu>
                                                    <ContextMenu
                                                        DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Edit], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnEditEntry"
                                                            Tag="{Binding}" />
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Rewrite], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnRewriteRound"
                                                            Tag="{Binding}" />
                                                        <MenuItem
                                                            Header="{Binding [Dialog.DeleteRound], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnDeleteRound"
                                                            Tag="{Binding}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>

                                        <Expander
                                            Header="{Binding [Dialog.ThinkingProcess], Source={x:Static loc:Loc.Instance}}"
                                            Margin="0,4,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Visibility="{Binding HasThinking, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding Thinking}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0" />
                                        </Expander>

                                        <!-- 内容区域: 三种状态重叠, 同一时刻只显示一个 -->
                                        <Grid Margin="0,4,0,0">
                                            <!-- 流式输出中: 纯文本, 不渲染 Markdown -->
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}}" />

                                            <!-- 正常显示: 渲染后的 Markdown -->
                                            <FlowDocumentScrollViewer Document="{Binding Document}"
                                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                      IsSelectionEnabled="True"
                                                                      VerticalScrollBarVisibility="Auto">
                                                <FlowDocumentScrollViewer.Style>
                                                    <Style TargetType="FlowDocumentScrollViewer">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </FlowDocumentScrollViewer.Style>
                                            </FlowDocumentScrollViewer>

                                            <!-- 编辑模式: TextBox 替换正文 -->
                                            <StackPanel
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <ui:TextBox
                                                    Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                    AcceptsReturn="True"
                                                    TextWrapping="Wrap"
                                                    MinHeight="100"
                                                    Margin="0,0,0,4" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <ui:Button
                                                        Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                                                        Icon="Save24"
                                                        Appearance="Primary"
                                                        Padding="12,6"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}" />
                                                    <ui:Button
                                                        Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                                                        Icon="Dismiss24"
                                                        Appearance="Secondary"
                                                        Padding="12,6"
                                                        Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DirectiveInput.Directives}"
                                      Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="10,6"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TypeDisplay}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <ui:TextBox Grid.Column="1"
                                                        Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                        TextWrapping="Wrap"
                                                        AcceptsReturn="True"
                                                        MinLines="1"
                                                        MaxLines="3"
                                                        VerticalAlignment="Center"
                                                        BorderThickness="0"
                                                        Background="Transparent" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Padding="12,8"
                                                        MinWidth="36"
                                                        Margin="2,0"
                                                        Command="{Binding DataContext.DirectiveInput.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="↑" FontSize="14" />
                                                </Button>
                                                <Button Padding="12,8"
                                                        MinWidth="36"
                                                        Margin="2,0"
                                                        Command="{Binding DataContext.DirectiveInput.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="↓" FontSize="14" />
                                                </Button>
                                                <Button Padding="12,8"
                                                        MinWidth="36"
                                                        Margin="2,0"
                                                        Command="{Binding DataContext.DirectiveInput.RemoveDirectiveCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="✕" FontSize="14" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Margin="0,0,4,0"
                                      SelectedIndex="0"
                                      SelectionChanged="OnDirectiveTypeChanged">
                                <ComboBoxItem
                                    Content="{Binding [Directive.Type.Plot], Source={x:Static loc:Loc.Instance}}" />
                                <ComboBoxItem
                                    Content="{Binding [Directive.Type.Tone], Source={x:Static loc:Loc.Instance}}" />
                                <ComboBoxItem
                                    Content="{Binding [Directive.Type.TemporaryConstraint], Source={x:Static loc:Loc.Instance}}" />
                                <ComboBoxItem
                                    Content="{Binding [Directive.Type.SceneChange], Source={x:Static loc:Loc.Instance}}" />
                            </ComboBox>
                            <ui:TextBox Grid.Column="1"
                                        Margin="4,0"
                                        PlaceholderText="{Binding [Dialog.InputPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        Text="{Binding DirectiveInput.InputContent, UpdateSourceTrigger=PropertyChanged}"
                                        KeyDown="OnInputKeyDown" />
                            <ui:Button Grid.Column="2"
                                       Content="{Binding [Dialog.AddDirective], Source={x:Static loc:Loc.Instance}}"
                                       Icon="Add24"
                                       Margin="4,0"
                                       Padding="12,6"
                                       Command="{Binding DirectiveInput.AddDirectiveCommand}" />
                            <ui:Button Grid.Column="3"
                                       Content="{Binding [Dialog.SendDirective], Source={x:Static loc:Loc.Instance}}"
                                       Icon="Send24"
                                       Appearance="Primary"
                                       Margin="4,0,0,0"
                                       Padding="16,6"
                                       Command="{Binding SendDirectivesCommand}"
                                       IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="3"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8,8,8,8">
                <StackPanel>
                    <ui:CardExpander Header="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [State.Panel.Scene], Source={x:Static loc:Loc.Instance}}"
                                           Foreground="Gray" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [State.Panel.Timeline], Source={x:Static loc:Loc.Instance}}"
                                           Foreground="Gray" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding StatePanel.TimelineLabel}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="{Binding [Directive.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding TtlLabel}"
                                                       FontSize="11"
                                                       Foreground="Gray"
                                                       Visibility="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>

                    <ui:CardExpander Header="{Binding [Character.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding CharacterPanel.Characters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="Gray" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="Gray"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</ui:FluentWindow>
