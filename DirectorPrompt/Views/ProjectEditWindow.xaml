<ui:FluentWindow x:Class="DirectorPrompt.Views.ProjectEditWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 xmlns:enums="clr-namespace:DirectorPrompt.Domain.Enums;assembly=DirectorPrompt.Domain"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:ProjectEditViewModel}"
                 Title="{Binding [Project.NewTitle], Source={x:Static loc:Loc.Instance}}"
                 Width="1000"
                 Height="720"
                 MinWidth="800"
                 MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Icon="pack://application:,,,/Assets/Images/Icon.ico">
    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:EnumDisplayConverter x:Key="EnumDisplay" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding TitleText}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0"
                      x:Name="NavList"
                      Background="{DynamicResource ControlFillColorTransparentBrush}"
                      BorderThickness="0"
                      Padding="4"
                      SelectionChanged="OnNavSelectionChanged"
                      SelectedIndex="0">
                <ListViewItem Tag="basic" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DocumentEdit24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Project.Basic.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="embedding" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DataLine24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Project.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="knowledge" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Book24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="state" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Gauge24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="character" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="People24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Character.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="audit" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Shield24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Audit.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="memory" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Brain24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="retrieval" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Search24" Width="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [Knowledge.Retrieval.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
            </ListView>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <!-- 基本信息 -->
                        <StackPanel x:Name="BasicPanel" Visibility="Visible">
                            <TextBlock Text="{Binding [Project.Basic.Name], Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="{Binding [Project.Basic.NamePlaceholder], Source={x:Static loc:Loc.Instance}}" />

                            <TextBlock Text="{Binding [Project.Basic.Description], Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Margin="0,16,0,4" />
                            <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="{Binding [Project.Basic.DescriptionPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        MinHeight="100"
                                        VerticalScrollBarVisibility="Auto" />

                            <TextBlock
                                Text="{Binding [Project.Basic.OpeningMessage], Source={x:Static loc:Loc.Instance}}"
                                FontWeight="SemiBold"
                                Margin="0,16,0,4" />
                            <ui:TextBox Text="{Binding OpeningMessage, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="{Binding [Project.Basic.OpeningMessagePlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        MinHeight="80"
                                        VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <!-- Embedding 配置 -->
                        <StackPanel x:Name="EmbeddingPanel" Visibility="Collapsed">
                            <TextBlock Text="{Binding [Project.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock
                                Text="{Binding [Project.Embedding.Description], Source={x:Static loc:Loc.Instance}}"
                                FontSize="12"
                                Foreground="Gray"
                                Margin="0,0,0,16" />
                            <TextBlock Text="{Binding [Settings.Agent.Provider], Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{x:Static vm:AgentSettingViewModel.AvailableProviders}"
                                      SelectedItem="{Binding Embedding.Provider}"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="{Binding [Settings.Agent.Endpoint], Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding Embedding.Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="留空使用默认值"
                                        Margin="0,0,0,12" />
                            <TextBlock Text="{Binding [Settings.Agent.APIKey], Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding Embedding.APIKey, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="本地模型可留空"
                                        Margin="0,0,0,12" />
                            <TextBlock Text="模型名" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding Embedding.ModelName, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:Button Content="{Binding [Settings.Agent.TestConnection], Source={x:Static loc:Loc.Instance}}"
                                       Icon="PlugConnected24"
                                       Appearance="Secondary"
                                       Margin="0,12,0,0"
                                       Command="{Binding TestEmbeddingConnectionCommand}"
                                       IsEnabled="{Binding Embedding.IsTestingConnection, Converter={StaticResource InverseBool}}" />

                            <TextBlock Text="{Binding Embedding.ConnectionMessage}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Embedding.ConnectionSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#107C10" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Embedding.ConnectionSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="OrangeRed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- 知识系统 (树状) -->
                        <StackPanel x:Name="KnowledgePanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1"
                                           Content="{Binding [Knowledge.AddGroup], Source={x:Static loc:Loc.Instance}}"
                                           Icon="Add24"
                                           Command="{Binding AddKnowledgeGroupCommand}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding KnowledgeGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardExpander Margin="0,0,0,8" IsExpanded="True">
                                            <ui:CardExpander.Header>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1"
                                                                Margin="0, 0, 8, 0"
                                                                Orientation="Horizontal">
                                                        <ui:Button
                                                            Content="{Binding [Knowledge.AddEntry], Source={x:Static loc:Loc.Instance}}"
                                                            Appearance="Secondary"
                                                            Icon="Add24"
                                                            Padding="6,4"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding DataContext.AddKnowledgeEntryCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                            CommandParameter="{Binding}" />
                                                        <ui:Button Content="删除"
                                                                   Appearance="Caution"
                                                                   Icon="Delete24"
                                                                   Padding="6,4"
                                                                   Click="OnDeleteKnowledgeGroup"
                                                                   Tag="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </ui:CardExpander.Header>

                                            <StackPanel>
                                                
                                                <CheckBox
                                                    Content="{Binding [Knowledge.Group.Enable], Source={x:Static loc:Loc.Instance}}"
                                                    IsChecked="{Binding Active}"
                                                    Margin="0,-4,0,8" />
                                                
                                                <TextBlock
                                                    Text="{Binding [Knowledge.Group.Name], Source={x:Static loc:Loc.Instance}}"
                                                    FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{Binding [Knowledge.Group.NamePlaceholder], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,0,0,12" />
                                                <TextBlock
                                                    Text="{Binding [Knowledge.Group.Description], Source={x:Static loc:Loc.Instance}}"
                                                    FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <ui:TextBox
                                                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="{Binding [Knowledge.Group.PlaceholderOptional], Source={x:Static loc:Loc.Instance}}"
                                                    Margin="0,0,0,12" />

                                                <TextBlock
                                                    Text="{Binding [Knowledge.Entry.Title], Source={x:Static loc:Loc.Instance}}"
                                                    FontWeight="SemiBold"
                                                    Margin="0,8,0,8" />
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,6"
                                                                    Padding="12,8"
                                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                Text="{Binding Title}"
                                                                                FontWeight="SemiBold"
                                                                                VerticalAlignment="Center" />
                                                                        <StackPanel Grid.Column="1"
                                                                                Orientation="Horizontal">
                                                                            <ui:Button
                                                                                Content="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}"
                                                                                Appearance="Secondary"
                                                                                Padding="6,4"
                                                                                Margin="0,0,4,0"
                                                                                Click="OnEditKnowledgeEntry"
                                                                                Tag="{Binding}" />
                                                                            <ui:Button
                                                                                Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                                                Appearance="Caution"
                                                                                Padding="6,4"
                                                                                Click="OnDeleteKnowledgeEntry"
                                                                                Tag="{Binding}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <StackPanel
                                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                        
                                                                        <CheckBox
                                                                            Content="{Binding [Knowledge.Entry.Active], Source={x:Static loc:Loc.Instance}}"
                                                                            IsChecked="{Binding Active}"
                                                                            Margin="0,8,0,4" />
                                                                        
                                                                        <TextBlock
                                                                            Text="{Binding [Knowledge.Entry.TitleLabel], Source={x:Static loc:Loc.Instance}}"
                                                                            Margin="0,8,0,4" />
                                                                        <ui:TextBox
                                                                            Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <TextBlock
                                                                            Text="{Binding [Knowledge.Entry.Content], Source={x:Static loc:Loc.Instance}}"
                                                                            Margin="0,8,0,4" />
                                                                        <ui:TextBox
                                                                            Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                                            AcceptsReturn="True"
                                                                            TextWrapping="Wrap"
                                                                            MinHeight="80"
                                                                            VerticalScrollBarVisibility="Auto" />
                                                                        <TextBlock
                                                                            Text="{Binding [Knowledge.Entry.Tags], Source={x:Static loc:Loc.Instance}}"
                                                                            Margin="0,8,0,4" />
                                                                        <ui:TextBox
                                                                            Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                                                                            PlaceholderText="{Binding [Knowledge.Entry.TagsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 状态系统 -->
                        <StackPanel x:Name="StatePanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1"
                                           Content="{Binding [State.AddAttribute], Source={x:Static loc:Loc.Instance}}"
                                           Icon="Add24"
                                           Appearance="Primary"
                                           Command="{Binding AddStateAttributeCommand}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding StateAttributes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2"
                                                Padding="12,8"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="Gray"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <ui:Button
                                                            Content="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}"
                                                            Appearance="Secondary"
                                                            Margin="0,0,4,0"
                                                            Click="OnEditStateAttribute"
                                                            Tag="{Binding}" />
                                                        <ui:Button
                                                            Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                            Appearance="Caution"
                                                            Click="OnDeleteStateAttribute"
                                                            Tag="{Binding}" />
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel
                                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                    <Grid Margin="0,8,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.Identifier], Source={x:Static loc:Loc.Instance}}"
                                                                Margin="0,0,0,4" />
                                                            <ui:TextBox
                                                                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.DisplayName], Source={x:Static loc:Loc.Instance}}"
                                                                Margin="0,0,0,4" />
                                                            <ui:TextBox
                                                                Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Margin="0,4,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.ValueType], Source={x:Static loc:Loc.Instance}}"
                                                                Margin="0,0,0,4" />
                                                            <ComboBox
                                                                ItemsSource="{Binding Source={x:Type enums:StateValueType}, Converter={StaticResource EnumDisplay}}"
                                                                SelectedItem="{Binding ValueType, Converter={StaticResource EnumDisplay}}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.Driver], Source={x:Static loc:Loc.Instance}}"
                                                                Margin="0,0,0,4" />
                                                            <ComboBox
                                                                ItemsSource="{Binding Source={x:Type enums:Driver}, Converter={StaticResource EnumDisplay}}"
                                                                SelectedItem="{Binding Driver, Converter={StaticResource EnumDisplay}}" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- numeric + narrative -->
                                                    <StackPanel Margin="0,8,0,0"
                                                                Visibility="{Binding IsNumericConfig, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.MinValue], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,0,0,4" />
                                                        <ui:NumberBox Value="{Binding MinValue}"
                                                                      Minimum="-999999"
                                                                      Maximum="999999"
                                                                      ClearButtonEnabled="True" />
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.MaxValue], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,8,0,4" />
                                                        <ui:NumberBox Value="{Binding MaxValue}"
                                                                      Minimum="-999999"
                                                                      Maximum="999999"
                                                                      ClearButtonEnabled="True" />
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.Unit], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,8,0,4" />
                                                        <ui:TextBox
                                                            Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{Binding [State.Attribute.UnitPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.ChangeRules], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,8,0,4" />
                                                        <ui:TextBox
                                                            Text="{Binding ChangeRules, UpdateSourceTrigger=PropertyChanged}"
                                                            AcceptsReturn="True"
                                                            TextWrapping="Wrap"
                                                            MinHeight="60"
                                                            VerticalScrollBarVisibility="Auto" />
                                                    </StackPanel>

                                                    <!-- enum + system -->
                                                    <StackPanel Margin="0,8,0,0"
                                                                Visibility="{Binding IsEnumConfig, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.Options], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,0,0,4" />
                                                        <ui:TextBox
                                                            Text="{Binding Options, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{Binding [State.Attribute.OptionsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.Trigger], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,8,0,4" />
                                                        <ComboBox
                                                            ItemsSource="{Binding Source={x:Type enums:SystemTrigger}, Converter={StaticResource EnumDisplay}}"
                                                            SelectedItem="{Binding Trigger, Converter={StaticResource EnumDisplay}}" />
                                                    </StackPanel>

                                                    <!-- composite + system -->
                                                    <StackPanel Margin="0,8,0,0"
                                                                Visibility="{Binding IsCompositeConfig, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.GenerationGuide], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,0,0,4" />
                                                        <ui:TextBox
                                                            Text="{Binding GenerationGuide, UpdateSourceTrigger=PropertyChanged}"
                                                            AcceptsReturn="True"
                                                            TextWrapping="Wrap"
                                                            MinHeight="60"
                                                            VerticalScrollBarVisibility="Auto" />
                                                        <TextBlock
                                                            Text="{Binding [State.Attribute.RegenerateTrigger], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,8,0,4" />
                                                        <ComboBox
                                                            ItemsSource="{Binding Source={x:Type enums:SystemTrigger}, Converter={StaticResource EnumDisplay}}"
                                                            SelectedItem="{Binding RegenerateTrigger, Converter={StaticResource EnumDisplay}}" />
                                                    </StackPanel>

                                                    <!-- Phase -->
                                                    <TextBlock Text="{Binding [State.Attribute.Phases], Source={x:Static loc:Loc.Instance}}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,12,0,4" />
                                                    <TextBlock Text="{Binding [State.Attribute.PhasesHint], Source={x:Static loc:Loc.Instance}}"
                                                               FontSize="11"
                                                               Foreground="Gray"
                                                               Margin="0,0,0,8" />
                                                    <ItemsControl ItemsSource="{Binding Phases}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,6"
                                                                        Padding="8,6"
                                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="4">
                                                                    <StackPanel>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center"
                                                                                           Margin="0,0,8,0" />
                                                                                <TextBlock Text="{Binding Expression}"
                                                                                           FontSize="11"
                                                                                           Foreground="Gray"
                                                                                           VerticalAlignment="Center" />
                                                                            </StackPanel>
