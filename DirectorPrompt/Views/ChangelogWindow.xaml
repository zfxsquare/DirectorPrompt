<ui:FluentWindow x:Class="DirectorPrompt.Views.ChangelogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 Title="{Binding [Changelog.Title], Source={x:Static loc:Loc.Instance}}"
                 Width="520"
                 MinWidth="0"
                 MinHeight="0"
                 Height="480"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="WindowTitleBar"
                     Grid.Row="0"
                     Margin="24,8,24,0"
                     ShowMaximize="False"
                     ShowClose="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <FlowDocumentScrollViewer x:Name="ChangelogViewer"
                                  Grid.Row="1"
                                  Margin="24,0,24,8"
                                  IsToolBarVisible="False"
                                  VerticalScrollBarVisibility="Auto" />

        <ui:Button x:Name="CloseButton"
                   Grid.Row="2"
                   HorizontalAlignment="Right"
                   Padding="20,6"
                   Margin="0,0,24,16"
                   Click="OnCloseClick" />
    </Grid>
</ui:FluentWindow>
