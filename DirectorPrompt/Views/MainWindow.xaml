<ui:FluentWindow x:Class="DirectorPrompt.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
                 Title="DirectorPrompt"
                 Width="1280"
                 Height="800"
                 MinWidth="960"
                 MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Icon="pack://application:,,,/Assets/Images/Icon.ico">
    <ui:FluentWindow.Resources>
        <Style x:Key="SidebarToggleStyle" TargetType="ui:Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="PART_Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="PART_Content" Property="TextElement.Foreground"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="ProjectItemContextMenu" x:Shared="False">
            <MenuItem
                Header="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}"
                Click="OnEditProjectItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem
                Header="{Binding [Navigation.ExportProject], Source={x:Static loc:Loc.Instance}}"
                Click="OnExportProjectItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem
                Header="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                Click="OnDeleteProjectItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <ContextMenu x:Key="SessionItemContextMenu" x:Shared="False">
            <MenuItem
                Header="{Binding [Common.Rename], Source={x:Static loc:Loc.Instance}}"
                Click="OnRenameSessionItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem
                Header="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                Click="OnDeleteSessionItem"
                Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="WindowTitleBar"
                     Grid.Row="0"
                     Title="DirectorPrompt">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Navigation.Project], Source={x:Static loc:Loc.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <ComboBox Width="300"
                              Margin="0,0,4,0"
                              ItemsSource="{Binding Projects}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding CurrentProject}"
                              IsEnabled="{Binding IsNotProcessing}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Setter Property="ContextMenu" Value="{StaticResource ProjectItemContextMenu}" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Margin="0,0,4,0"
                               Command="{Binding EditProjectCommand}"
                               IsEnabled="{Binding CanInteractProject}"
                               ToolTip="{Binding [Navigation.EditProject], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="Edit24" />
                    </ui:Button>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Command="{Binding NewProjectCommand}"
                               IsEnabled="{Binding IsNotProcessing}"
                               ToolTip="{Binding [Navigation.NewProject], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="Add24" />
                    </ui:Button>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Margin="4,0,0,0"
                               Command="{Binding ExportProjectCommand}"
                               IsEnabled="{Binding CanInteractProject}"
                               ToolTip="{Binding [Navigation.ExportProject], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="ArrowExportUp24" />
                    </ui:Button>
                    <ui:Button Appearance="Secondary"
                               Padding="8,6"
                               Margin="4,0,0,0"
                               Command="{Binding ImportProjectCommand}"
                               IsEnabled="{Binding IsNotProcessing}"
                               ToolTip="{Binding [Navigation.ImportProject], Source={x:Static loc:Loc.Instance}}">
                        <ui:SymbolIcon Symbol="ArrowImport24" />
                    </ui:Button>
                </StackPanel>

                <ui:Button Grid.Column="2"
                           Content="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}"
                           Icon="{ui:SymbolIcon Symbol=Settings24}"
                           Appearance="Secondary"
                           Padding="12,6"
                           Command="{Binding OpenSettingsCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="240"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:Button Grid.Row="0"
                               Content="{Binding [Navigation.NewSession], Source={x:Static loc:Loc.Instance}}"
                               Icon="{ui:SymbolIcon Symbol=Add24}"
                               Appearance="Primary"
                               Command="{Binding NewSessionCommand}"
                               IsEnabled="{Binding CanInteractProject}"
                               Margin="0,8,8,12"
                               HorizontalAlignment="Stretch" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding CurrentSession}"
                             IsEnabled="{Binding CanInteractProject}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,0,8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="ContextMenu" Value="{StaticResource SessionItemContextMenu}" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding PipelineStages}"
                              Margin="16,4,16,4"
                              Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource ControlElevationBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                <Setter Property="Opacity" Value="0.6" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Stage}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer x:Name="DialogScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,8">
                    <ItemsControl ItemsSource="{Binding Dialog.Entries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        MaxWidth="720"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource ControlElevationBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirector}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Role}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Top" />

                                            <Button Grid.Column="2"
                                                    Click="OnMoreButtonClick"
                                                    Padding="6,2"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding IsLast, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="⋯" FontSize="14" />
                                                <Button.ContextMenu>
                                                    <ContextMenu
                                                        DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Edit], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnEditEntry"
                                                            Tag="{Binding}" />
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Rollback], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnRollbackRound"
                                                            Tag="{Binding}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>

                                        <Expander
                                            Header="{Binding [Dialog.ThinkingProcess], Source={x:Static loc:Loc.Instance}}"
                                            Margin="0,4,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Visibility="{Binding HasThinking, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding Thinking}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0" />
                                        </Expander>

                                        <!-- 内容区域: 三种状态重叠, 同一时刻只显示一个 -->
                                        <Grid Margin="0,4,0,0">
                                            <!-- 导演指令: 按指令分块渲染 Markdown -->
                                            <ItemsControl ItemsSource="{Binding DirectorBlocks}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDirectorBlocks}"
                                                                         Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,4"
                                                                Padding="8,6"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TypeDisplay}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           Margin="0,0,0,2" />
                                                                <FlowDocumentScrollViewer Document="{Binding Document}"
                                                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                        IsSelectionEnabled="True"
                                                                        VerticalScrollBarVisibility="Disabled"
                                                                        PreviewMouseWheel="OnFlowDocumentPreviewMouseWheel" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 叙事输出: 渲染后的 Markdown (含流式) -->
                                            <FlowDocumentScrollViewer Document="{Binding Document}"
                                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                      IsSelectionEnabled="True"
                                                                      VerticalScrollBarVisibility="Disabled"
                                                                      PreviewMouseWheel="OnFlowDocumentPreviewMouseWheel">
                                                <FlowDocumentScrollViewer.Style>
                                                    <Style TargetType="FlowDocumentScrollViewer">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDirectorBlocks}"
                                                                         Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </FlowDocumentScrollViewer.Style>
                                            </FlowDocumentScrollViewer>

                                            <!-- 编辑模式: TextBox 替换正文 -->
                                            <StackPanel
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <ui:TextBox
                                                    Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                    AcceptsReturn="True"
                                                    TextWrapping="Wrap"
                                                    MinHeight="100"
                                                    Margin="0,0,0,4" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <ui:Button
                                                        Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                                                        Icon="{ui:SymbolIcon Symbol=Save24}"
                                                        Appearance="Primary"
                                                        Padding="12,6"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}" />
                                                    <ui:Button
                                                        Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                                                        Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                                        Appearance="Secondary"
                                                        Padding="12,6"
                                                        Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                        CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <components:DirectiveInputControl DirectiveInput="{Binding DirectiveInput}"
                                                          ShowSendButton="True"
                                                          SendCommand="{Binding SendDirectivesCommand}"
                                                          IsProcessing="{Binding IsProcessing}" />
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="2"
                          Width="3"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <ScrollViewer Grid.Column="3"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8,8,8,8">
                <StackPanel>
                    <ui:CardExpander Header="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [State.Panel.Scene], Source={x:Static loc:Loc.Instance}}"
                                           Foreground="Gray" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="{Binding [Directive.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding TTLLabel}"
                                                       FontSize="11"
                                                       Foreground="Gray"
                                                       Visibility="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>

                    <ui:CardExpander Header="{Binding [Character.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding CharacterPanel.Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4"
                                            Padding="0"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <!-- 分组标题栏 -->
                                            <ToggleButton IsChecked="{Binding IsExpanded}"
                                                          Cursor="Hand"
                                                          Padding="14,10"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="HeaderBg"
                                                                Background="Transparent"
                                                                CornerRadius="6,6,0,0"
                                                                Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <ui:SymbolIcon x:Name="Chevron"
                                                                               Grid.Column="0"
                                                                               Symbol="ChevronDown24"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,8,0" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding CategoryName}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <Border Grid.Column="2"
                                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                        CornerRadius="8"
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center"
                                                                        Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding ItemCount}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Chevron" Property="Symbol"
                                                                        Value="ChevronUp24" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="HeaderBg" Property="Background"
                                                                        Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <!-- 人物条目列表 -->
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="10,0,10,10"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,3, 0, 3"
                                                                Padding="12, 10, 12, 0"
                                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0"
                                                                            Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                FontWeight="SemiBold"
                                                                                Margin="0,0,8,0" />
                                                                    </StackPanel>
                                                                    <ToggleButton Grid.Column="1"
                                                                            IsChecked="{Binding IsExpanded}"
                                                                            Padding="0"
                                                                            Cursor="Hand"
                                                                            VerticalAlignment="Center">
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <ui:SymbolIcon x:Name="DetailChevron"
                                                                                    Symbol="ChevronDown24"
                                                                                    FontSize="12"
                                                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked"
                                                                                        Value="True">
                                                                                        <Setter
                                                                                            TargetName="DetailChevron"
                                                                                            Property="Symbol"
                                                                                            Value="ChevronUp24" />
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsMouseOver"
                                                                                        Value="True">
                                                                                        <Setter
                                                                                            TargetName="DetailChevron"
                                                                                            Property="Foreground"
                                                                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </ToggleButton.Template>
                                                                    </ToggleButton>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Description}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="12"
                                                                           Foreground="Gray"
                                                                           Margin="0,4,0,0" />
                                                                <TextBlock Text="{Binding Categories}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                           Margin="0,4,0,0" />

                                                                <StackPanel
                                                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                                    Margin="0,8,0,0">
                                                                    <TextBlock Text="状态"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               Margin="0,0,0,4"
                                                                               Visibility="{Binding HasStateValues, Converter={StaticResource BoolToVisibility}}" />
                                                                    <ItemsControl ItemsSource="{Binding StateValues}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,2">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                        Text="{Binding Name}"
                                                                                        FontSize="11"
                                                                                        TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock Grid.Column="1"
                                                                                        Text="{Binding Value}"
                                                                                        FontSize="11"
                                                                                        FontWeight="SemiBold"
                                                                                        Margin="8,0,0,0" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <TextBlock Text="关系"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               Margin="0,8,0,4"
                                                                               Visibility="{Binding HasRelations, Converter={StaticResource BoolToVisibility}}" />
                                                                    <ItemsControl ItemsSource="{Binding Relations}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock FontSize="11"
                                                                                    TextWrapping="Wrap">
                                                                                    <Run Text="{Binding Direction}" />
                                                                                    <Run Text="{Binding Target}"
                                                                                        FontWeight="SemiBold" />
                                                                                    <Run Text=": " />
                                                                                    <Run Text="{Binding Type}" />
                                                                                </TextBlock>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>

                    <ui:CardExpander Header="{Binding [Memory.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                     IsExpanded="True"
                                     Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding MemoryPanel.Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4"
                                            Padding="0"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <!-- 分组标题栏 -->
                                            <ToggleButton IsChecked="{Binding IsExpanded}"
                                                          Cursor="Hand"
                                                          Padding="14,10"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="HeaderBg"
                                                                Background="Transparent"
                                                                CornerRadius="6,6,0,0"
                                                                Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <ui:SymbolIcon x:Name="Chevron"
                                                                               Grid.Column="0"
                                                                               Symbol="ChevronDown24"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,8,0" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding SceneLabel}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <Border Grid.Column="2"
                                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                        CornerRadius="8"
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center"
                                                                        Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding ItemCount}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="White" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Chevron" Property="Symbol"
                                                                        Value="ChevronUp24" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="HeaderBg" Property="Background"
                                                                        Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <!-- 记忆条目列表 -->
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="10,0,10,10"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,3"
                                                                Padding="12,10"
                                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <StackPanel>
                                                                <!-- 非编辑模式 -->
                                                                <StackPanel
                                                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding UpdatedAtDisplay}"
                                                                                FontSize="10"
                                                                                Foreground="Gray"
                                                                                VerticalAlignment="Center"
                                                                                DockPanel.Dock="Left" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                HorizontalAlignment="Right"
                                                                                DockPanel.Dock="Right">
                                                                            <ui:Button Appearance="Secondary"
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnEditMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}">
                                                                                <ui:SymbolIcon Symbol="Edit24"
                                                                                    FontSize="12" />
                                                                            </ui:Button>
                                                                            <ui:Button Appearance="Secondary"
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnDeleteMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}">
                                                                                <ui:SymbolIcon Symbol="Delete24"
                                                                                    FontSize="12" />
                                                                            </ui:Button>
                                                                        </StackPanel>
                                                                    </DockPanel>
                                                                    <TextBlock Text="{Binding Content}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock Text="{Binding TagsDisplay}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,4,0,0"
                                                                               Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}" />
                                                                    <TextBlock Text="{Binding RelatedCharacters}"
                                                                               FontSize="11"
                                                                               Foreground="Gray"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,4,0,0"
                                                                               Visibility="{Binding HasRelatedCharacters, Converter={StaticResource BoolToVisibility}}" />
                                                                </StackPanel>

                                                                <!-- 编辑模式 -->
                                                                <StackPanel
                                                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                    <ui:TextBox
                                                                        Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                                        AcceptsReturn="True"
                                                                        TextWrapping="Wrap"
                                                                        MinHeight="80" />
                                                                    <ui:TextBox
                                                                        Text="{Binding EditingTags, UpdateSourceTrigger=PropertyChanged}"
                                                                        Margin="0,4,0,0"
                                                                        PlaceholderText="{Binding [Memory.Panel.TagsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                    <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            Margin="0,4,0,0">
                                                                        <ui:Button
                                                                            Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                                                                            Icon="{ui:SymbolIcon Symbol=Save24}"
                                                                            Appearance="Primary"
                                                                            Padding="12,6"
                                                                            Margin="0,0,4,0"
                                                                            Command="{Binding DataContext.SaveMemoryEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                                            CommandParameter="{Binding}" />
                                                                        <ui:Button
                                                                            Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                                                                            Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                                                            Appearance="Secondary"
                                                                            Padding="12,6"
                                                                            Command="{Binding DataContext.CancelMemoryEditCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                                            CommandParameter="{Binding}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CardExpander>
                </StackPanel>
            </ScrollViewer>

            <ui:Button Grid.Column="0"
                       Style="{StaticResource SidebarToggleStyle}"
                       Width="20"
                       Height="36"
                       Command="{Binding ToggleSessionSidebarCommand}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="236,0,0,0"
                       Visibility="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}}"
                       ToolTip="{Binding [Navigation.CollapseSidebar], Source={x:Static loc:Loc.Instance}}">
                <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="12" />
            </ui:Button>

            <ui:Button Grid.Column="0"
                       Style="{StaticResource SidebarToggleStyle}"
                       Width="20"
                       Height="36"
                       Command="{Binding ToggleSessionSidebarCommand}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       Visibility="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                       ToolTip="{Binding [Navigation.ExpandSidebar], Source={x:Static loc:Loc.Instance}}">
                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="12" />
            </ui:Button>
        </Grid>

    </Grid>
</ui:FluentWindow>
